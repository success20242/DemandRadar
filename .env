# =========================
# 🚀 SERVER CONFIG
# =========================
PORT=5000
NODE_ENV=development

# =========================
# 🤖 GROQ AI CONFIG
# =========================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# =========================
# 🌍 FRONTEND URL (CORS)
# =========================
FRONTEND_URL=http://localhost:3000

# =========================
# 📊 DATA ENGINE (FUTURE APIs)
# =========================
GOOGLE_TRENDS_API_KEY=pytrends
NEWS_API_KEY=39758596128d4d36b3c2322dac4814ca

# =========================
# 🧠 AI SETTINGS
# =========================
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024

# =========================
# 📄 PDF ENGINE
# =========================
PUPPETEER_EXECUTABLE_PATH=

# =========================
# 🔌 WEBSOCKET CONFIG
# =========================
WS_PATH=/ws
WS_INTERVAL=8000

# =========================
# 📁 STATIC FILES
# =========================
PUBLIC_URL=http://localhost:5000

# =========================
# 🔐 SECURITY (OPTIONAL)
# =========================
JWT_SECRET=super_secret_key_change_this
